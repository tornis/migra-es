{
  "name": "migra-es",
  "version": "1.0.0",
  "description": "Elasticsearch index migration tool from v2/5/6 to v8/9 — interactive TUI with live progress, pause/resume, and multi-index support",
  "type": "module",
  "bin": {
    "migra-es": "./bin/es-migrate.js"
  },
  "scripts": {
    "start":          "tsx src/cli/index.jsx",
    "dev":            "tsx watch src/cli/index.jsx",
    "prepublishOnly": "node -e \"require('fs').chmodSync('bin/es-migrate.js', 0o755)\"",
    "test":           "echo \"Error: no test specified\" && exit 1"
  },
  "files": [
    "bin/",
    "src/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "elasticsearch",
    "migration",
    "es5",
    "es6",
    "es9",
    "tui",
    "cli",
    "reindex"
  ],
  "author": "Rodrigo Tornis <contato@tornis.com.br> (https://www.tornis.com.br)",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "bull":                   "^4.12.0",
    "chalk":                  "^5.3.0",
    "cli-spinners":           "^3.4.0",
    "dotenv":                 "^16.3.1",
    "figures":                "^6.0.1",
    "gradient-string":        "^3.0.0",
    "ink":                    "^4.4.1",
    "ink-select-input":       "^5.0.0",
    "ink-spinner":            "^5.0.0",
    "ink-text-input":         "^5.0.1",
    "ioredis":                "^5.3.2",
    "lowdb":                  "^7.0.1",
    "nanospinner":            "^1.2.2",
    "p-queue":                "^8.0.1",
    "react":                  "^18.2.0",
    "tsx":                    "^4.7.0",
    "uuid":                   "^9.0.1",
    "winston":                "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod":                    "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "esbuild":     "^0.19.11"
  }
}
