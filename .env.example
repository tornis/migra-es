# Elasticsearch Source Configuration
ES_SOURCE_URL=http://localhost:9200
ES_SOURCE_USER=
ES_SOURCE_PASS=
ES_SOURCE_SSL=false
ES_SOURCE_REJECT_UNAUTHORIZED=true

# Elasticsearch Destination Configuration
ES_DEST_URL=http://localhost:9200
ES_DEST_USER=
ES_DEST_PASS=
ES_DEST_SSL=false
ES_DEST_REJECT_UNAUTHORIZED=true

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Migration Performance Settings
BULK_SIZE=1000
WORKER_THREADS=4
SCROLL_SIZE=5000
SCROLL_TIMEOUT=5m
CACHE_TTL=3600
MAX_RETRIES=3
RETRY_DELAY=1000

# Logging Configuration
LOG_LEVEL=info
LOG_DIR=./logs
LOG_MAX_FILES=14d
LOG_MAX_SIZE=20m

# Application Settings
DATA_DIR=./data
ENABLE_CACHE=true
