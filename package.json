{
  "name": "es-migration-tool",
  "version": "1.0.0",
  "description": "Elasticsearch 5 to 9 migration tool with TUI interface",
  "main": "dist/bundle.js",
  "type": "module",
  "bin": {
    "es-migrate": "./bin/es-migrate.js"
  },
  "scripts": {
    "start": "tsx src/cli/index.jsx",
    "dev": "tsx watch src/cli/index.jsx",
    "prepublishOnly": "chmod +x bin/es-migrate.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "pkg": {
    "assets": [
      "node_modules/ioredis/**/*",
      "node_modules/bull/**/*",
      "node_modules/@elastic/elasticsearch/**/*",
      "node_modules/lowdb/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "elasticsearch",
    "migration",
    "es5",
    "es9",
    "tui",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@elastic/elasticsearch": "^8.12.0",
    "bull": "^4.12.0",
    "chalk": "^5.3.0",
    "cli-spinners": "^3.4.0",
    "dotenv": "^16.3.1",
    "figures": "^6.0.1",
    "gradient-string": "^3.0.0",
    "ink": "^4.4.1",
    "ink-select-input": "^5.0.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.1",
    "ioredis": "^5.3.2",
    "lowdb": "^7.0.1",
    "nanospinner": "^1.2.2",
    "p-queue": "^8.0.1",
    "react": "^18.2.0",
    "tsx": "^4.7.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@vercel/ncc": "^0.38.1",
    "esbuild": "^0.19.11",
    "pkg": "^5.8.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
